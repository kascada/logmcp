name: "{{ logmcp_name | default('logmcp-' + inventory_hostname) }}"

server:
  host: "127.0.0.1"
  port: {{ logmcp_port | default(7788) }}
  tls:
    mode: "off"

proxy:
  enabled: {{ logmcp_proxy_enabled | default(true) | lower }}
  trusted_proxy: true
  domain: "{{ logmcp_proxy_domain }}"
  path_prefix: "{{ logmcp_path_prefix | default('/logmcp') }}"
  caddy: true

auth:
  tokens:
    - name: "{{ logmcp_token_name | default('default') }}"
      token: "{{ logmcp_token }}"
      scopes: ["read"]

logs:
  whitelist:
{% for path in logmcp_whitelist | default(['/var/log/*']) %}
    - "{{ path }}"
{% endfor %}

{% if logmcp_macros_dir is defined and logmcp_macros_dir %}
extensions:
  macros:
    dir: "{{ logmcp_macros_dir }}"

{% endif %}
{% if logmcp_rag_enabled | default(false) %}
redis:
  addr: "{{ logmcp_redis_addr | default('127.0.0.1:6379') }}"
{% if logmcp_redis_password is defined and logmcp_redis_password %}
  password: "{{ logmcp_redis_password }}"
{% endif %}
{% if logmcp_redis_key_prefix is defined and logmcp_redis_key_prefix %}
  key_prefix: "{{ logmcp_redis_key_prefix }}"
{% endif %}

rag:
  ollama_url: "{{ logmcp_rag_ollama_url | default('http://127.0.0.1:11434') }}"
  embedding_model: "{{ logmcp_rag_embedding_model | default('nomic-embed-text') }}"
{% if logmcp_rag_sources is defined and logmcp_rag_sources %}
  sources:
{% for source in logmcp_rag_sources %}
    - name: "{{ source.name }}"
      path: "{{ source.path }}"
{% endfor %}
{% endif %}

{% endif %}
audit:
  syslog: true

security:
  fail2ban:
    enabled: {{ logmcp_fail2ban_enabled | default(true) | lower }}
{% if logmcp_rate_limit_max_failures is defined %}
  rate_limit:
    max_failures: {{ logmcp_rate_limit_max_failures }}
    window_seconds: {{ logmcp_rate_limit_window_seconds | default(60) }}
{% endif %}
